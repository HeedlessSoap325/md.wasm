{
	"name": "svelte-src",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev:wasm": "cargo watch -s \"wasm-pack build --target web --out-dir src/wasm --out-name lib --dev\"",
		"dev:vite": "vite dev",
		"dev": "concurrently \"npm:dev:wasm\" \"npm:dev:vite\"",
		
		"build:wasm" : "wasm-pack build --target web --out-dir src/wasm --out-name lib --release",
		"build:vite": "vite build",
		"build": "npm run build:wasm && npm run build:vite",
	
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.9.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	}
}
